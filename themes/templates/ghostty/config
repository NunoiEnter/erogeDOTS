# Ghostty config — generated by theme-switch
# Template: themes/templates/ghostty/config

# Font
font-family = monospace
font-size = 11

# Cursor
cursor-style = bar
cursor-style-blink = true

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = false
background-opacity = 0.8
background-blur-radius = 20

# Scrollback
scrollback-limit = 10000

# Bell
# (no bell config needed)

# Mouse
mouse-hide-while-typing = true

# Shell
shell-integration = zsh

# Theme colors — overridden by theme-switch
background = {{BG}}
foreground = {{FG}}
cursor-color = {{PRIMARY}}
selection-background = {{PRIMARY}}
selection-foreground = {{BG}}

# Normal colors
palette = 0=#15161e
palette = 1=#f7768e
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#7aa2f7
palette = 5={{PRIMARY}}
palette = 6=#7dcfff
palette = 7=#a9b1d6

# Bright colors
palette = 8=#414868
palette = 9=#f7768e
palette = 10=#9ece6a
palette = 11=#e0af68
palette = 12=#7aa2f7
palette = 13={{PRIMARY_LIGHT}}
palette = 14=#7dcfff
palette = 15={{FG}}
