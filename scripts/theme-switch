#!/usr/bin/env bash
# theme-switch: instant desktop theme changer for erogeDOTS
# Usage: theme-switch <theme-name> | list | current

set -euo pipefail

DOTFILES="$HOME/erogeDOTS"
THEMES_DIR="$DOTFILES/themes"
STATE_DIR="$HOME/.config/theme"
STATE_FILE="$STATE_DIR/active"
TEMPLATES_DIR="$THEMES_DIR/templates"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    echo -e "${MAGENTA}erogeDOTS Theme Switcher${NC}"
    echo ""
    echo "Usage:"
    echo "  theme-switch <theme>    Switch to theme"
    echo "  theme-switch list       List available themes"
    echo "  theme-switch current    Show current theme"
    echo "  theme-switch preview    Preview theme colors"
    echo ""
    echo "Available themes:"
    for theme_dir in "$THEMES_DIR"/*/; do
        theme_name=$(basename "$theme_dir")
        [[ "$theme_name" == "templates" ]] && continue
        echo -e "  ${CYAN}$theme_name${NC}"
    done
}

list_themes() {
    echo -e "${MAGENTA}Available themes:${NC}"
    echo ""
    for theme_dir in "$THEMES_DIR"/*/; do
        theme_name=$(basename "$theme_dir")
        [[ "$theme_name" == "templates" ]] && continue
        
        if [[ -f "$STATE_FILE" ]] && [[ "$(cat "$STATE_FILE")" == "$theme_name" ]]; then
            echo -e "  ${GREEN}● $theme_name${NC} ${YELLOW}(active)${NC}"
        else
            echo -e "  ${CYAN}○ $theme_name${NC}"
        fi
        
        if [[ -f "$theme_dir/theme.conf" ]]; then
            primary=$(grep "^primary " "$theme_dir/theme.conf" | head -1 | cut -d'=' -f2 | xargs)
            echo -e "    primary: ${primary}"
        fi
    done
}

current_theme() {
    if [[ -f "$STATE_FILE" ]]; then
        echo -e "${GREEN}Current theme:${NC} $(cat "$STATE_FILE")"
    else
        echo -e "${YELLOW}No theme set${NC}"
    fi
}

# Parse theme.conf into associative array
parse_theme() {
    local theme_name="$1"
    local conf_file="$THEMES_DIR/$theme_name/theme.conf"
    
    if [[ ! -f "$conf_file" ]]; then
        echo -e "${RED}Theme not found: $theme_name${NC}"
        exit 1
    fi
    
    declare -gA COLORS
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        [[ "$key" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$key" ]] && continue
        
        key=$(echo "$key" | xargs)
        value=$(echo "$value" | xargs)
        
        # Convert to template variable name
        var_name=$(echo "$key" | tr '[:lower:]' '[:upper:]' | tr '-' '_')
        COLORS[$var_name]="$value"
    done < "$conf_file"
}

# Apply template with color substitution
apply_template() {
    local template="$1"
    local output="$2"
    
    cp "$template" "$output"
    
    for key in "${!COLORS[@]}"; do
        sed -i "s|{{${key}}}|${COLORS[$key]}|g" "$output"
    done
}

# Generate all configs for a theme
generate_configs() {
    local theme_name="$1"
    local theme_dir="$THEMES_DIR/$theme_name"
    
    # Create cache directory
    local cache_dir="$STATE_DIR/cache/$theme_name"
    mkdir -p "$cache_dir"
    
    # Parse theme colors
    parse_theme "$theme_name"
    
    # Generate niri config
    if [[ -f "$TEMPLATES_DIR/niri/config.kdl" ]]; then
        mkdir -p "$cache_dir/niri"
        apply_template "$TEMPLATES_DIR/niri/config.kdl" "$cache_dir/niri/config.kdl"
    fi
    
    # Generate waybar configs
    if [[ -f "$TEMPLATES_DIR/waybar/config.jsonc" ]]; then
        mkdir -p "$cache_dir/waybar"
        apply_template "$TEMPLATES_DIR/waybar/config.jsonc" "$cache_dir/waybar/config.jsonc"
        apply_template "$TEMPLATES_DIR/waybar/style.css" "$cache_dir/waybar/style.css"
    fi
    
    # Generate fastfetch config
    if [[ -f "$TEMPLATES_DIR/fastfetch/config.jsonc" ]]; then
        mkdir -p "$cache_dir/fastfetch"
        apply_template "$TEMPLATES_DIR/fastfetch/config.jsonc" "$cache_dir/fastfetch/config.jsonc"
    fi
    
    # Generate fuzzel config
    if [[ -f "$TEMPLATES_DIR/fuzzel/config.ini" ]]; then
        mkdir -p "$cache_dir/fuzzel"
        apply_template "$TEMPLATES_DIR/fuzzel/config.ini" "$cache_dir/fuzzel/config.ini"
    fi
    
    # Generate foot config
    if [[ -f "$TEMPLATES_DIR/foot/foot.ini" ]]; then
        mkdir -p "$cache_dir/foot"
        apply_template "$TEMPLATES_DIR/foot/foot.ini" "$cache_dir/foot/foot.ini"
    fi
    
    echo -e "${GREEN}Generated configs for $theme_name${NC}"
}

# Apply theme configs - removes HM symlinks, copies files directly
apply_theme() {
    local theme_name="$1"
    local cache_dir="$STATE_DIR/cache/$theme_name"
    
    local apps=("niri" "waybar" "fastfetch" "fuzzel" "foot")
    
    for app in "${apps[@]}"; do
        local target="$HOME/.config/$app"
        local source_dir="$DOTFILES/config/$app"
        local theme_dir="$cache_dir/$app"
        
        # Remove Home Manager symlink if it exists
        if [[ -L "$target" ]]; then
            rm "$target"
        fi
        
        # Create directory if it doesn't exist
        if [[ ! -d "$target" ]]; then
            mkdir -p "$target"
        fi
        
        # Copy base configs from dotfiles (only if target is empty)
        if [[ -d "$source_dir" ]] && [[ -z "$(ls -A "$target" 2>/dev/null)" ]]; then
            cp -r "$source_dir"/* "$target"/ 2>/dev/null || true
        fi
        
        # Overwrite with theme-specific configs
        if [[ -d "$theme_dir" ]]; then
            cp -r "$theme_dir"/* "$target"/ 2>/dev/null || true
        fi
    done
    
    echo -e "${GREEN}Applied theme: $theme_name${NC}"
    
    # Flush all writes to disk before restarting apps
    sync
}

# Apply wallpaper via awww
apply_wallpaper() {
    local theme_name="$1"
    local conf_file="$THEMES_DIR/$theme_name/theme.conf"
    local wallpaper
    wallpaper=$(grep "^wallpaper" "$conf_file" | head -1 | cut -d'=' -f2 | xargs)
    
    if [[ -n "$wallpaper" ]]; then
        # Expand ~ to $HOME
        wallpaper="${wallpaper/#\~/$HOME}"
        if [[ -f "$wallpaper" ]]; then
            awww img "$wallpaper" --transition-type fade 2>/dev/null || true
            echo -e "  ${GREEN}wallpaper set${NC}"
        else
            echo -e "  ${YELLOW}wallpaper not found: $wallpaper${NC}"
        fi
    fi
}

# Restart affected apps
restart_apps() {
    local theme_name="$1"
    echo -e "${YELLOW}Restarting apps...${NC}"
    
    # Kill ALL running waybar instances (Nix wraps as .waybar-wrapped)
    while pgrep -f "waybar" > /dev/null; do
        pkill -f "waybar" 2>/dev/null || true
        sleep 0.1
    done
    
    # Set wallpaper
    apply_wallpaper "$theme_name"
    
    # Reload niri config (colors, focus ring, etc.)
    if pgrep -x "niri" > /dev/null; then
        niri msg action reload-config 2>/dev/null || true
        echo -e "  ${GREEN}niri config reloaded${NC}"
    fi
    
    # Spawn fresh waybar with new theme
    waybar &
    disown
    echo -e "  ${GREEN}waybar restarted${NC}"
    
    echo -e "  ${CYAN}fastfetch: next launch will use new theme${NC}"
}

# Preview theme colors
preview_theme() {
    local theme_name="${1:-$(cat "$STATE_FILE" 2>/dev/null || echo "")}"
    
    if [[ -z "$theme_name" ]]; then
        echo -e "${RED}No theme specified${NC}"
        return 1
    fi
    
    parse_theme "$theme_name"
    
    echo -e "${MAGENTA}Theme: $theme_name${NC}"
    echo ""
    echo -e "  Primary:     ${COLORS[PRIMARY]}"
    echo -e "  Primary Lt:  ${COLORS[PRIMARY_LIGHT]}"
    echo -e "  Primary Dk:  ${COLORS[PRIMARY_DARK]}"
    echo -e "  Background:  ${COLORS[BG]}"
    echo -e "  Foreground:  ${COLORS[FG]}"
    echo ""
    echo -e "  Niri focus:  ${COLORS[NIRI_FOCUS_ACTIVE]}"
    echo -e "  Waybar bg:   ${COLORS[WAYBAR_BG_GRADIENT]}"

}

# Main
main() {
    mkdir -p "$STATE_DIR"
    
    case "${1:-}" in
        list)
            list_themes
            ;;
        current)
            current_theme
            ;;
        preview)
            preview_theme "${2:-}"
            ;;
        help|-h|--help)
            usage
            ;;
        "")
            usage
            exit 1
            ;;
        *)
            local theme_name="$1"
            
            # Check theme exists
            if [[ ! -d "$THEMES_DIR/$theme_name" ]]; then
                echo -e "${RED}Theme not found: $theme_name${NC}"
                echo "Run 'theme-switch list' to see available themes"
                exit 1
            fi
            
            echo -e "${MAGENTA}Switching to theme: $theme_name${NC}"
            
            # Generate configs
            generate_configs "$theme_name"
            
            # Apply configs
            apply_theme "$theme_name"
            
            # Save state
            echo "$theme_name" > "$STATE_FILE"
            
            # Restart apps
            restart_apps "$theme_name"
            
            echo ""
            echo -e "${GREEN}Theme switched to: $theme_name${NC}"
            echo -e "${CYAN}Preview: theme-switch preview${NC}"
            ;;
    esac
}

main "$@"
